{% extends "@AppBundle/Base/base.html.twig" %}

{% block title %}Accueil - {{ parent() }}{% endblock %}

{% block css %}
    <link rel="canonical" href="https://aamv.net" />
    <style>
    /* ===== HOMEPAGE FULLPAGE SCROLL ===== */
    html { min-height: unset; height: 100%; overflow: hidden; }
    body { min-height: unset; height: 100vh; overflow-x: hidden; overflow-y: scroll; scroll-snap-type: y mandatory; }
    #body { display: contents; }

    /* Hero = 1re section snap */
    .hero { height: 100vh; min-height: unset; scroll-snap-align: start; overflow: hidden; display: flex; flex-direction: column; padding-top: 70px; padding-bottom: 1rem; }
    .hero-content { flex: 1; padding: 1.5rem 2rem 0; }
    .hero-pattern { display: none; }
    .stats { flex-shrink: 0; margin: 0.5rem auto 1rem; width: calc(100% - 4rem); max-width: 900px; }

    /* Sections snap */
    #news, #services, .about-section, .adhesion-section, .cta-section {
        height: 100vh; scroll-snap-align: start; overflow: hidden;
        padding: 2rem; display: flex; flex-direction: column; justify-content: center;
    }
    footer { scroll-snap-align: start; }

    /* Headers compacts */
    .section-header { margin-bottom: 1.2rem; }
    .section-header h2 { font-size: 1.85rem; margin-bottom: 0.2rem; }
    .section-header p { font-size: 0.9rem; }

    /* News 2 colonnes */
    .news-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; max-width: 1100px; }
    .news-year-divider {
        grid-column: 1 / -1;
        display: flex; align-items: center; gap: 0.8rem;
        font-family: 'Bubblegum Sans', cursive; font-size: 1rem;
        color: var(--warm-orange); font-weight: 700;
        margin: 0.3rem 0 0.1rem;
    }
    .news-year-divider::before, .news-year-divider::after {
        content: ''; flex: 1; height: 1px; background: var(--light-peach);
    }
    .news-card { padding: 0.85rem 1.1rem; }
    .news-card h3 { font-size: 0.87rem; }
    .news-icon { width: 40px; height: 40px; font-size: 20px; border-radius: 10px; }

    /* Services compacts */
    .services-grid { gap: 1rem; }
    .service-card { padding: 1.3rem; }
    .service-card p { font-size: 0.82rem; line-height: 1.4; }
    .service-icon { width: 48px; height: 48px; font-size: 22px; margin-bottom: 0.6rem; }
    .service-card h3 { font-size: 1.1rem; margin-bottom: 0.4rem; }

    /* About compact */
    .about-content { gap: 2rem; }
    .about-images { height: 270px; }
    .about-img-1 { width: 190px; height: 215px; font-size: 56px; }
    .about-img-2 { width: 170px; height: 185px; font-size: 50px; }
    .about-floating-badge { width: 86px; height: 86px; }
    .about-text h2 { font-size: 1.7rem; margin-bottom: 0.4rem; }
    .about-text p { font-size: 0.87rem; margin-bottom: 0.4rem; line-height: 1.5; }
    .about-features { margin: 0.4rem 0 0; }
    .about-features li { padding: 0.2rem 0; font-size: 0.83rem; }

    /* Adhésion compact */
    .adhesion-grid { gap: 1rem; }
    .adhesion-card { padding: 1.2rem; }

    /* CTA compact */
    .cta-box { padding: 2.5rem; }
    .cta-box h2 { font-size: 1.8rem; }
    .cta-box p { margin-bottom: 1.2rem; font-size: 0.93rem; }
    </style>
{% endblock css %}

{% block body_style %}{% endblock %}

{% block hero %}
<header class="hero" id="accueil">
    <div class="hero-bg"></div>
    <div class="hero-content">
        <div class="hero-text">
            <h1>Bienvenue à <span class="highlight">l'A.A.M.V.</span></h1>
            <p>L'<strong>Association des Assistantes Maternelles Villeneuvoises</strong> et des Parents et ses Environs.</p>
            <p>Retrouvez des outils utiles, des petites annonces, des informations pour assistantes maternelles et parents de <strong>Villeneuve d'Ascq</strong>.</p>
            <div class="hero-buttons">
                <a href="{{ path('services_ads_index') }}" class="btn btn-primary">📋 Petites annonces</a>
                <a href="{{ path('services_disponibilities') }}" class="btn btn-outline">🔍 Disponibilités</a>
            </div>
        </div>
        <div class="hero-image">
            <div class="hero-img-wrapper">
                <div class="hero-img-inner">
                    <img src="{{ asset('bundles/app/images/logo.png') }}" alt="Logo AAMV - Association des Assistantes Maternelles Villeneuvoises">
                </div>
            </div>
            <div class="hero-badge badge-1">
                <div class="badge-icon">🌿</div>
                <div><strong>Agréées PMI</strong><br><small style="color:#9B8A7C">Professionnelles</small></div>
            </div>
            <div class="hero-badge badge-2">
                <div class="badge-icon">❤️</div>
                <div><strong>{{ assistants_count }} adhérentes</strong><br><small style="color:#9B8A7C">Ass. maternelles</small></div>
            </div>
        </div>
    </div>
    <div class="stats">
        <div class="stat-item">
            <div class="stat-number">{{ assistants_count }}</div>
            <div class="stat-label">Assistantes maternelles</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-number">1997</div>
            <div class="stat-label">Année de création</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-number">28</div>
            <div class="stat-label">Années d'expérience</div>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Bénévole & solidaire</div>
        </div>
    </div>
</header>
{% endblock %}

{% block body %}
    {% for flash in app.session.flashbag.get('management.legacy_password.success') %}
        <div class="alert alert-success">{{ flash }}</div>
    {% endfor %}

    <!-- News Section -->
    <section id="news">
        <div class="section-header reveal">
            <div class="section-tag">Actualités</div>
            <h2>Les dernières nouvelles</h2>
            <p>Toute l'info pour les assistantes maternelles et les parents</p>
        </div>
        <div class="news-grid">
            {% set icons = ['📄', '💰', '🔒', '📝', '⚖️', '📋', '🤝', '🗺️', '📢', '🏠', '📅', '🌟'] %}
            {% set currentYear = null %}
            {% for new in news %}
                {% set year = new.createdAt|date('Y') %}
                {% if year != currentYear %}
                    <div class="news-year-divider">{{ year }}</div>
                    {% set currentYear = year %}
                {% endif %}
                <a href="{{ path('homepage_new', {'id': new.id}) }}" class="news-card reveal">
                    <div class="news-icon">{{ icons[loop.index0 % icons|length] }}</div>
                    <h3>{{ new.title|raw|slice(0, 120) }}{% if new.title|length > 120 %}...{% endif %}</h3>
                    {% if new.important %}
                        <span class="news-badge important">Important</span>
                    {% elseif loop.index <= 2 %}
                        <span class="news-badge">Nouveau</span>
                    {% endif %}
                </a>
            {% endfor %}
        </div>

        {% include '@AppBundle/Base/pagination.html.twig' %}
    </section>

    <!-- Services Section -->
    <section id="services">
        <div class="section-header reveal">
            <div class="section-tag">Nos Services</div>
            <h2>Ce que nous proposons</h2>
            <p>Des outils et services pour faciliter le quotidien des assistantes maternelles et des parents</p>
        </div>
        <div class="services-grid">
            <a href="{{ path('services_ads_index') }}" class="service-card reveal">
                <div class="service-icon">📢</div>
                <h3>Petites annonces</h3>
                <p>Publiez ou consultez les annonces d'assistantes maternelles et de parents pour trouver le bon accueil pour vos enfants.</p>
            </a>
            <a href="{{ path('services_disponibilities') }}" class="service-card reveal">
                <div class="service-icon">📅</div>
                <h3>Disponibilités</h3>
                <p>Consultez les disponibilités des assistantes maternelles de l'association pour trouver rapidement une place d'accueil.</p>
            </a>
            <a href="{{ path('services_tools', {"type": "public"}) }}" class="service-card reveal">
                <div class="service-icon">🛠️</div>
                <h3>Outils libres</h3>
                <p>Accédez gratuitement à nos calculateurs et outils pratiques pour la mensualisation, les congés payés et plus encore.</p>
            </a>
            <a href="{{ path('services_tools', {"type": "members"}) }}" class="service-card reveal">
                <div class="service-icon">⭐</div>
                <h3>Outils adhérents</h3>
                <p>Des outils exclusifs réservés aux adhérents : fiches de paie, contrats de travail, simulateurs avancés...</p>
            </a>
            <a href="{{ path('services_docs', {"type": "public"}) }}" class="service-card reveal">
                <div class="service-icon">📁</div>
                <h3>Documents libres</h3>
                <p>Documents d'information accessibles à tous : guides, textes de référence, modèles de base.</p>
            </a>
            <a href="{{ path('services_docs', {"type": "members"}) }}" class="service-card reveal">
                <div class="service-icon">📂</div>
                <h3>Documents adhérents</h3>
                <p>Bibliothèque complète de documents réservés aux adhérents : contrats, fiches techniques, formulaires à jour.</p>
            </a>
        </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="apropos">
        <div class="about-content">
            <div class="about-images reveal">
                <div class="about-img about-img-1">👶</div>
                <div class="about-img about-img-2">🏡</div>
                <div class="about-floating-badge">
                    <span>Depuis</span>
                    <span>1997</span>
                </div>
            </div>
            <div class="about-text reveal">
                <div class="section-tag">Qui sommes-nous ?</div>
                <h2>L'A.A.M.V., votre association</h2>
                <p>L'A.A.M.V. est une association à but non lucratif, loi de 1901, enregistrée en Novembre 1997. Elle réunit et accompagne les assistantes maternelles et les parents de <strong>Villeneuve d'Ascq et ses environs</strong>.</p>
                <p>Notre objectif : sortir les assistantes maternelles de leur isolement, favoriser l'entraide, le partage d'information et offrir un point de rencontre entre professionnelles et familles.</p>
                <ul class="about-features">
                    <li><span class="check">✓</span> Réunions régulières et échanges professionnels</li>
                    <li><span class="check">✓</span> Cadre juridique respecté : droit du travail, convention collective, agrément PMI</li>
                    <li><span class="check">✓</span> Contrats de travail clairs et à jour, fiches techniques de mensualisation</li>
                    <li><span class="check">✓</span> Service de remplacement en cas de maladie</li>
                    <li><span class="check">✓</span> Orientation et mise en relation parents / assistantes maternelles</li>
                    <li><span class="check">✓</span> Information sur les aides à l'emploi d'une assistante maternelle agréée</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Adhesion CTA -->
    <section class="adhesion-section">
        <div class="section-header reveal">
            <div class="section-tag">Adhésions {{ "now"|date("Y") }}</div>
            <h2>Rejoignez l'association !</h2>
            <p>Choisissez votre type d'adhésion et bénéficiez de tous les services de l'A.A.M.V.</p>
        </div>
        <div class="adhesion-grid">
            {% for tool in toolRepository.findValidJoin %}
            <a href="{{ path('files_join', {year: tool.year}) }}" class="adhesion-card reveal">
                <div class="card-emoji">👩‍🍼</div>
                <div>
                    <h3>Assistante Maternelle {{ tool.year }}</h3>
                    <p>Accès complet aux outils, documents, annonces et services réservés aux professionnelles.</p>
                </div>
            </a>
            {% endfor %}
            <a href="https://aamv.net/public/adhesion-parents-2026.pdf" class="adhesion-card reveal">
                <div class="card-emoji">👨‍👩‍👧</div>
                <div>
                    <h3>Parents</h3>
                    <p>Consultez les annonces, trouvez une assistante maternelle et accédez aux ressources parents.</p>
                </div>
            </a>
            <a href="https://aamv.net/public/adhesion-mam-3-2026.pdf" class="adhesion-card reveal">
                <div class="card-emoji">🏠</div>
                <div>
                    <h3>MAM 3</h3>
                    <p>Adhésion pour les Maisons d'Assistantes Maternelles (3 professionnelles).</p>
                </div>
            </a>
            <a href="https://aamv.net/public/adhesion-mam-4-2026.pdf" class="adhesion-card reveal">
                <div class="card-emoji">🏡</div>
                <div>
                    <h3>MAM 4</h3>
                    <p>Adhésion pour les Maisons d'Assistantes Maternelles (4 professionnelles).</p>
                </div>
            </a>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section" id="divers">
        <div class="cta-box reveal">
            <h2>Besoin d'aide ? 🌻</h2>
            <p>Consultez notre FAQ, nos sites utiles ou contactez-nous directement. Notre permanence est ouverte du lundi au vendredi de 14h à 16h.</p>
            <div class="cta-buttons">
                <a href="{{ path('divers_questions_answers') }}" class="btn btn-primary">❓ Questions / Réponses</a>
                <a href="{{ path('divers_sites') }}" class="btn btn-outline">🔗 Sites utiles</a>
            </div>
            <p style="margin-top:1.5rem;font-size:0.9rem;">
                📧 <a href="mailto:nounounathaamv@gmail.com" style="color:var(--warm-orange);font-weight:700;">nounounathaamv@gmail.com</a>
                &nbsp;·&nbsp;
                📞 <a href="tel:+33670972990" style="color:var(--warm-orange);font-weight:700;">06.70.97.29.90</a>
            </p>
        </div>
    </section>
{% endblock %}
